{
  "name": "StackScope",
  "displayName": "StackScope",
  "publisher": "EightLayerStudio",
  "author": {
    "name": "Josue Guevara"
  },
  "description": "StackScope provides flexible memory inspection with support for multiple numeric formats (hex, decimal, octal), stack-focused views, and register tracking such as SP and PC. Designed for low-level debugging workflows, it helps developers understand how memory changes during execution.",
  "version": "0.1.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PoncheDeFrutas/StackScope.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebug",
    "onCommand:stackscope.openMemoryView",
    "onCommand:stackscope.openMemoryViewInEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stackscope.openMemoryView",
        "title": "Open Memory View",
        "category": "StackScope"
      },
      {
        "command": "stackscope.focusMemoryView",
        "title": "Focus Memory View",
        "category": "StackScope"
      },
      {
        "command": "stackscope.openMemoryViewInEditor",
        "title": "Open Memory View (Editor Tab)",
        "category": "StackScope"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "stackscope.openMemoryView"
        },
        {
          "command": "stackscope.focusMemoryView"
        },
        {
          "command": "stackscope.openMemoryViewInEditor"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "stackscope-panel",
          "title": "StackScope",
          "icon": "$(debug-stackframe)"
        }
      ]
    },
    "views": {
      "stackscope-panel": [
        {
          "type": "webview",
          "id": "stackscope.memoryView",
          "name": "Memory",
          "contextualTitle": "StackScope Memory"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "vsix": "npx @vscode/vsce package --no-dependencies",
    "vsix:publish": "npx @vscode/vsce publish --no-dependencies",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
